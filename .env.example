# Copy this file to .env and fill in the values.
# .env is git-ignored — NEVER commit real secrets.

# GitHub Personal Access Token for the vike-io private repo (data tooling / history).
github_vikeio_full_token=

# vike.io API key (starts with vk_) — used by data/vike_source.py to pull OHLCV
# candles via the `ohlcv` MCP tool. Get one at https://vike.io/account?tab=api-keys
vikeio_full_token=

# --- Options chain: stock/index backend ---
# Default: the Options space uses the free yfinance feed for stocks/indices (delayed; bid/ask
# read 0 when the market is closed, so IV/greeks are inferred from the last trade price).
# For proper bid/ask/IV/greeks pick a backend via `options_stock_provider` + that key:
#   * "marketdata" -> marketdata.app; its FREE tier returns delayed greeks. Key: https://www.marketdata.app
#   * "polygon"    -> Polygon.io; needs a PAID "Options" entitlement (free tier 403s on the snapshot).
# Crypto (Deribit) is unaffected and needs no key.
options_stock_provider=    # "marketdata" | "polygon" | (blank -> yfinance)
marketdata_api_key=
polygon_api_key=

# Risk-free rate for Black–Scholes Theor/greeks (e.g. 0.04 for 4%). Blank -> 0.0.
options_risk_free=
