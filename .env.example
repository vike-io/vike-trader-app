# Copy this file to .env and fill in the values.
# .env is git-ignored — NEVER commit real secrets.

# GitHub Personal Access Token for the vike-io private repo (data tooling / history).
github_vikeio_full_token=

# vike.io API key (starts with vk_) — used by data/vike_source.py to pull OHLCV
# candles via the `ohlcv` MCP tool. Get one at https://vike.io/account?tab=api-keys
vikeio_full_token=

# --- Options chain: stock/index backend ---
# Default: the Options space uses the free yfinance feed for stocks/indices (delayed; bid/ask
# read 0 when the market is closed, so IV/greeks are inferred from the last trade price).
# For proper bid/ask/IV/greeks pick a backend via `options_stock_provider` + that key/token:
#   * "tradier"    -> Tradier sandbox; FREE forever (no funding), delayed chains WITH greeks/IV.
#                     Get a sandbox token at https://developer.tradier.com (Sandbox Access).
#   * "marketdata" -> marketdata.app; 30-day trial (10k credits/day), then paid. https://www.marketdata.app
#   * "polygon"    -> Polygon.io; needs a PAID "Options" entitlement (free tier 403s on the snapshot).
# Crypto (Deribit) is unaffected and needs no key.
options_stock_provider=    # "tradier" | "marketdata" | "polygon" | (blank -> yfinance)
tradier_token=
marketdata_api_key=
polygon_api_key=

# Risk-free rate for Black–Scholes Theor/greeks (e.g. 0.04 for 4%). Blank -> 0.0.
options_risk_free=

# --- MCP usage telemetry (opt-in; OFF by default) ---
# Records each MCP tool call (name, timing, ok/error, a SAFE arg summary — strategy
# source is never sent, only a sha+len). The MCP server does NOT load this .env, so
# when shipping set these in the MCP launch environment (Claude Desktop / Cursor server
# "env" block), not just here.
VIKE_TELEMETRY=            # 1/true/on/yes to enable (blank -> off)
VIKE_TELEMETRY_URL=        # e.g. https://telemetry.vike.io/telemetry (blank -> local JSONL only)
VIKE_TELEMETRY_TOKEN=      # shared secret; sent as the x-vike-token header (must match the receiver)
VIKE_TELEMETRY_DIR=        # local log + client-id dir (blank -> storage/telemetry)

# --- Live execution (Binance spot demo; GUI process only — gated OFF by default) ---
# Live exec is enabled only when VIKE_EXEC_VENUE+VIKE_EXEC_ENV are set AND these creds are present.
# Funded demo account at https://demo-api.binance.com (NOT the old testnet.binance.vision).
VIKE_EXEC_VENUE=           # "binance" to arm live exec (blank -> paper, the default)
VIKE_EXEC_ENV=             # "DEMO" | "MAINNET" (blank -> SIM/paper)
BINANCE_DEMO_API_KEY=      # demo HMAC key (blank -> stay paper)
BINANCE_DEMO_API_SECRET=   # demo HMAC secret (blank -> stay paper)
BINANCE_DEMO_BASE_URL=     # REST host override (blank -> https://demo-api.binance.com)
BINANCE_DEMO_WS_URL=       # user-data WS host override (blank -> resolved default; VERIFY empirically)
