# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.so
.Python
pip-wheel-metadata/

# ---- Scratch screenshots / renders dropped in the repo root ----
/*.png

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Packaging artifacts (PyInstaller / Nuitka) ----
*.spec
*.build/
*.dist/
*.onefile-build/

# ---- Local data & caches (actual price files / DBs are artifacts, not source) ----
# storage/ folder structure is kept via .gitkeep; the data files themselves are ignored by extension below
*.parquet
*.duckdb
*.db
*.sqlite
*.sqlite3
# JSON-backed runtime stores (Alerts / Journal tabs, Economic Calendar cache, data-source
# profiles) — per-user data, recreated on demand. `**` covers nested dirs too
# (e.g. storage/parquet/profiles/*.json); it subsumes the old storage/*.json rule.
storage/**/*.json
# cached source favicons for the News space (fetched on demand, per-user)
storage/news_logos/

# ---- Test / coverage ----
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ---- Secrets / env ----
.env
*.key

# ---- Dev artifacts (offscreen screenshots, scratch) ----
# All scratch PNGs/outputs go under tmp/ (kept as a dir via .gitkeep)
tmp/*
!tmp/.gitkeep
.playwright-mcp/
_shot_*.png
_pytest.txt
_val.txt
# stdout/stderr from launching the GUI detached (Start-Process … > launch.out.log 2> launch.err.log)
launch.*.log

# ---- OS ----
.DS_Store
Thumbs.db

# ---- IDE ----
.idea/
*.swp

# ---- Claude Code (local tooling config, not shared) ----
.claude/
.superpowers/

# ---- Private notes / design docs (NOT shared publicly) ----
docs/
